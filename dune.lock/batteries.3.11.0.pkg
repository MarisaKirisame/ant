(version 3.11.0)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (dune ocaml camlp-streams ocamlfind num)))

(source
 (fetch
  (url
   https://github.com/ocaml-batteries-team/batteries-included/releases/download/v3.11.0/batteries-3.11.0.tar.gz)
  (checksum
   sha512=621dca842c4a7adf0ac1e907bf44c1405e0b66a088987a138a4f4e98ca744815913bf87fd780619151cb049a07d7fdb1e8adb7b65698ab46b8c2dfe46cd7119d)))
